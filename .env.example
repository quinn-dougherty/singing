# Upstash Redis (Vercel Marketplace → Storage → Upstash) powers the queue.
# Without these, the app falls back to an in-memory store (LOCAL DEV ONLY —
# state will NOT persist across requests when deployed to Vercel).
#
# The Vercel Upstash integration sets KV_REST_API_* automatically. For local
# dev, copy this file to .env.local and fill either pair:

KV_REST_API_URL=
KV_REST_API_TOKEN=

# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
